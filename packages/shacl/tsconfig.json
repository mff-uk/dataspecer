{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "moduleResolution": "Node16",
    "outDir": "lib",
    "sourceMap": true,
    "target": "ESNext",
    "skipLibCheck": true,
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "src/tests/*.spec.ts", "node_modules/*"
  ]
}
